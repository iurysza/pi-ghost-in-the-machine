{
  "name": "pi-ghost-in-the-machine",
  "version": "0.1.0",
  "description": "A Ghostty face that reacts to Pi lifecycle states",
  "license": "MIT",
  "author": "Iury Souza",
  "keywords": [
    "pi-package",
    "pi-extension",
    "ghostty",
    "shader",
    "herdr",
    "lifecycle"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iurysza/pi-ghost-in-the-machine.git"
  },
  "bugs": "https://github.com/iurysza/pi-ghost-in-the-machine/issues",
  "homepage": "https://github.com/iurysza/pi-ghost-in-the-machine#readme",
  "type": "module",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "files": [
    "src",
    "scripts",
    "shaders",
    "herdr-plugin.toml",
    "AGENTS.md",
    "ai-artifacts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "check": "tsc --noEmit && bash -n scripts/*.sh",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "generate": "bash scripts/generate-variants.sh",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
